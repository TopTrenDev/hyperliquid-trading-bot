# Copy to .env and fill in. Never commit .env.

# Required for live orders (0x-prefixed hex private key)
HL_PRIVATE_KEY=

# Optional: 0x address to poll positions when TRADING_ENABLED=false
HL_USER_ADDRESS=

# mainnet | testnet
HL_NETWORK=mainnet

# Perpetual symbol on the main DEX (e.g. BTC, ETH)
HL_COIN=BTC

# Must be explicit true to send orders
TRADING_ENABLED=true

# Cross margin (true) or isolated (false)
HL_CROSS_MARGIN=true

# Target leverage (clamped to coin max from metadata)
HL_LEVERAGE=3

# Max absolute position notional in USD (approximate, uses mid)
MAX_POSITION_USD=500

# Per-order notional in USD (approximate, uses mid)
ORDER_NOTIONAL_USD=50

# Minimum milliseconds between order submissions
ORDER_COOLDOWN_MS=15000

# IOC limit offset from mid (basis points) for aggressive fills
IOC_SLIPPAGE_BPS=50

# Strategy: noop | dual_ma
STRATEGY=dual_ma

# dual_ma: moving averages over last N mid ticks (WS cadence varies)
DUAL_MA_FAST=12
DUAL_MA_SLOW=48
# Entry/exit band in basis points vs slow average
DUAL_MA_BAND_BPS=8

# How often the decision loop runs (ms)
TICK_INTERVAL_MS=2000
